# ── LLM Provider ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── SerpAPI (real-time news & research) ──
SERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Auth ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Production URL (prevents redirect to Render preview ports) ──
NEXT_PUBLIC_SITE_URL=https://careerdeck.xyz

# ── Google OAuth (configured in Supabase Dashboard) ──
# Enable Google provider in: https://supabase.com/dashboard/project/<ref>/auth/providers
# Google Cloud Console redirect URI:
#   https://<ref>.supabase.co/auth/v1/callback

# ── Razorpay Payments ──
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
