# REQUIRED: Your LLM API configuration
# Pick ONE provider and uncomment the relevant lines:

# ── Option 1: OpenAI (GPT-4o / GPT-4o-mini) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── Option 2: OpenRouter (access Claude, Gemini, etc.) ──
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Option 3: Anthropic (Claude directly) ──
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── OPTIONAL: SerpAPI for real-time news (Section 2) ──
# Get your key at https://serpapi.com
# SERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Dossier Mode ──
# The frontend has a toggle — no env config needed.
# "Beginner" = warm, explains every term, full STAR stories
# "Executive" = no definitions, plug-and-play blueprints, [X%] brackets

# ── Google OAuth (required for sign-in) ──
# Get credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://careerdeck.xyz/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── NextAuth ──
# Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXTAUTH_URL=https://careerdeck.xyz
